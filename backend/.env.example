# Copy to backend/.env and fill in your values. NEVER commit the real .env.

# NVIDIA NIM — chat, embeddings, rerank.  Get a key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith tracing (optional). Leave TRACING off if you don't use it.
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=atlas

# Supabase (values shown are the local self-hosted defaults).
SUPABASE_URL=http://localhost:8000
SUPABASE_KEY=your-supabase-anon-or-publishable-key

# Postgres — a direct asyncpg connection (the local self-hosted db is exposed on
# :5433 via docker-compose.override.yml). In production ONLY this URL changes;
# point it at hosted Supabase and the code is identical.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5433/postgres

# NVIDIA NIM rate budget (free tier hard cap is 40 req/min across ALL calls).
NVIDIA_MAX_RPM=35
NVIDIA_BURST=5

# Models (streamed via SSE).
CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b
CHAT_FAST_MODEL=nvidia/nvidia-nemotron-nano-9b-v2
CHAT_TEMPERATURE=0.2
# CORS — the deployed frontend origin(s) allowed to call this API. Set to your
# Vercel URL in production. Extra origins can be comma-separated in
# FRONTEND_ORIGINS. localhost is always allowed for dev.
FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGINS=https://your-app.vercel.app,https://atlas.example.com

# Embedding dimension MUST match the vector() size in schema.sql (2048).
EMBEDDING_DIM=2048

# Docling master switch. Leave "true" on hosts with >=2 GB RAM (full PDF parsing:
# tables + layout). Set "false" on small/constrained free tiers (e.g. Render's
# 512 MB) — every PDF then uses the low-memory text-only extractor: you lose
# table/layout structure but PDF ingestion still works and won't OOM.
DOCLING_ENABLED=true
